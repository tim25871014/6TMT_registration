PORT=3000

OSU_CLIENT_ID=your_osu_oauth_client_id
OSU_CLIENT_SECRET=your_osu_oauth_client_secret
OSU_REDIRECT_URI=http://localhost:3000/auth/osu/callback

# Set USE_POSTGRES=true only when you really want to use PostgreSQL
# (e.g. in Railway). For simple local testing, leave it empty or false
# to use local JSON file storage under data/participants.json.
USE_POSTGRES=false

DATABASE_URL=postgresql://user:password@host:port/dbname
PGSSLMODE=require

# Optional: admin page protection
# If set, /api/admin/participants requires header:
#   Authorization: Bearer YOUR_TOKEN
ADMIN_TOKEN=some-strong-secret-token
